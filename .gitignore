# =============================================================================
# Resume Craft for Claude Code — Git 忽略规则
# 用户个人数据不上传；示例数据（sample）例外允许提交
# =============================================================================

# Python
__pycache__/
*.pyc
.venv/

# User data (personal info — excluded from git)
data/input/*
!data/input/.gitkeep
data/profiles/*
data/output/*

# Sample data (demo purpose — included in git)
!data/profiles/sample.json
!data/output/sample/

# Node.js (installed by tools/setup)
node_modules/
tools/node_modules/

# IDE
.vscode/
.idea/

# Lint cache
.pytest_cache/
.eslintcache

# Logs
logs/*
!logs/.gitkeep

# OS
.DS_Store
Thumbs.db

# Local settings & backups
.claude/settings.local.json
*.local.json
*.bak
