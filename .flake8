[flake8]
# Resume Craft for Claude Code — Python Lint Config
max-line-length = 120
exclude =
    .git,
    __pycache__,
    .venv,
    node_modules,
    logs,
    data,
ignore =
    E203,  # whitespace before ':'
    W503,  # line break before binary operator
    E501,  # line too long (handled by max-line-length)
per-file-ignores =
    __init__.py:F401
