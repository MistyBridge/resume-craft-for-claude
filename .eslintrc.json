{
  "comment": "Resume Craft for Claude Code — Node.js Lint Config",
  "env": {
    "node": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest"
  },
  "rules": {
    "no-unused-vars": ["warn", { "argsIgnorePattern": "^_" }],
    "no-console": "off",
    "semi": ["warn", "always"],
    "quotes": ["warn", "double"]
  },
  "ignorePatterns": ["node_modules/", "logs/", "data/"]
}
